{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 15,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "desktop-debug",
      "displayName": "Desktop Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-desktop",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "TANH_WITH_RTSAN": true
      }
    },
    {
      "name": "desktop-release",
      "displayName": "Desktop Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-desktop",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "ios-simulator-debug",
      "displayName": "iOS Simulator Debug",
      "generator": "Xcode",
      "binaryDir": "${sourceDir}/build-ios-simulator",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchain/ios.toolchain.cmake",
        "THL_IOS_PLATFORM": "SIMULATOR",
        "BUILD_SHARED_LIBS": "OFF"
      }
    },
    {
      "name": "ios-simulator-release",
      "displayName": "iOS Simulator Release",
      "generator": "Xcode",
      "binaryDir": "${sourceDir}/build-ios-simulator",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchain/ios.toolchain.cmake",
        "THL_IOS_PLATFORM": "SIMULATOR",
        "BUILD_SHARED_LIBS": "OFF"
      }
    },
    {
      "name": "ios-device-debug",
      "displayName": "iOS Device Debug",
      "generator": "Xcode",
      "binaryDir": "${sourceDir}/build-ios-device",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchain/ios.toolchain.cmake",
        "THL_IOS_PLATFORM": "DEVICE",
        "BUILD_SHARED_LIBS": "OFF"
      }
    },
    {
      "name": "ios-device-release",
      "displayName": "iOS Device Release",
      "generator": "Xcode",
      "binaryDir": "${sourceDir}/build-ios-device",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchain/ios.toolchain.cmake",
        "THL_IOS_PLATFORM": "DEVICE",
        "BUILD_SHARED_LIBS": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "desktop-debug",
      "configurePreset": "desktop-debug",
      "configuration": "Debug"
    },
    {
      "name": "desktop-release",
      "configurePreset": "desktop-release",
      "configuration": "Release"
    },
    {
      "name": "ios-simulator-debug",
      "configurePreset": "ios-simulator-debug",
      "configuration": "Debug"
    },
    {
      "name": "ios-simulator-release",
      "configurePreset": "ios-simulator-release",
      "configuration": "Release"
    },
    {
      "name": "ios-device-debug",
      "configurePreset": "ios-device-debug",
      "configuration": "Debug",
      "nativeToolOptions": ["-allowProvisioningUpdates"]
    },
    {
      "name": "ios-device-release",
      "configurePreset": "ios-device-release",
      "configuration": "Release",
      "nativeToolOptions": ["-allowProvisioningUpdates"]
    }
  ],
  "testPresets": [
    {
      "name": "desktop-debug",
      "configurePreset": "desktop-debug",
      "configuration": "Debug",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "desktop-release",
      "configurePreset": "desktop-release",
      "configuration": "Release",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "ios-simulator-debug",
      "configurePreset": "ios-simulator-debug",
      "configuration": "Debug",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "ios-simulator-release",
      "configurePreset": "ios-simulator-release",
      "configuration": "Release",
      "output": { "outputOnFailure": true }
    }
  ]
}
