{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "iOS Simulator: Build Audio IO Example",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset", "ios-simulator-debug",
                "--target", "audio_io"
            ],
            "group": "build",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "iOS Simulator: Launch Audio IO Example",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/run-ios-sim.sh",
            "args": [
                "${workspaceFolder}/build-ios-simulator/examples/ios/audio-io/Debug-iphonesimulator/audio_io.app"
            ],
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "^$",
                    "file": 1,
                    "location": 2,
                    "message": 3
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".",
                    "endsPattern": "com\\.tanh\\.audio-io-example"
                }
            }
        },
        {
            "label": "iOS Simulator: Build & Launch Audio IO Example",
            "dependsOn": [
                "iOS Simulator: Build Audio IO Example",
                "iOS Simulator: Launch Audio IO Example"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": []
        },
        {
            "label": "iOS Device: Build Audio IO Example",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset", "ios-device-debug",
                "--target", "audio_io"
            ],
            "group": "build",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "iOS Device: Launch Audio IO Example",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/run-ios-device.sh",
            "args": [
                "${workspaceFolder}/build-ios-device/examples/ios/audio-io/Debug-iphoneos/audio_io.app"
            ],
            "options": {
                "env": {
                    "IOS_DEVICE_UDID": "27E7756C-9D5A-528A-9E10-EAB0394B90FF"
                }
            },
            "problemMatcher": []
        },
        {
            "label": "iOS Device: Build & Launch Audio IO Example",
            "dependsOn": [
                "iOS Device: Build Audio IO Example",
                "iOS Device: Launch Audio IO Example"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": []
        }
    ]
}
