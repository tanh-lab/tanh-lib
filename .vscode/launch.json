    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch CMake Target",
            "type": "lldb",
            "request": "launch",
            "program": "${command:cmake.launchTargetPath}",
            "args": [],
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Attach to iOS Simulator (Audio IO Example)",
            "type": "lldb",
            "request": "attach",
            "program": "${workspaceFolder}/build/ios-iphonesimulator/Debug/examples/ios/audio-io/Debug-iphonesimulator/audio_io.app/audio_io",
            "waitFor": true,
            "preLaunchTask": "iOS Simulator: Build & Launch Audio IO Example"
        }
    ]
}